{{- define "reviewer-tools" -}}
{{- if eq .Role "code-reviewer"}}

REVIEWER TOOL{{toolSearchHint .ToolPrefix "liza_get,liza_submit_verdict,liza_await_resubmission"}}:
- {{.ToolPrefix}}liza_submit_verdict — Submit review verdict (see VERDICT SUBMISSION below for params)
- {{.ToolPrefix}}liza_await_resubmission — Block until doer resubmits after rejection (call after submit_verdict REJECTED)
  {"task_id": "{{.TaskID}}", "agent_id": "{{.AgentID}}"}
{{- else}}

{{- if eq .Role "code-plan-reviewer"}}
CODE PLAN REVIEWER TOOLS{{toolSearchHint .ToolPrefix "liza_get,liza_submit_verdict,liza_await_resubmission"}}:
{{- else if eq .Role "epic-plan-reviewer"}}
EPIC PLAN REVIEWER TOOLS{{toolSearchHint .ToolPrefix "liza_get,liza_submit_verdict,liza_await_resubmission"}}:
{{- else if eq .Role "us-reviewer"}}
US REVIEWER TOOLS{{toolSearchHint .ToolPrefix "liza_get,liza_submit_verdict,liza_await_resubmission"}}:
{{- else if eq .Role "architecture-reviewer"}}
ARCHITECTURE REVIEWER TOOLS{{toolSearchHint .ToolPrefix "liza_get,liza_submit_verdict,liza_await_resubmission"}}:
{{- end}}
- {{.ToolPrefix}}liza_get — Query task state to inspect output[] entries
  {"query": "tasks/{{.TaskID}}"}
- {{.ToolPrefix}}liza_submit_verdict — Submit review verdict (MCP tool call, NOT a CLI command)
  ⚠️  Do NOT use `go run`, `liza submit-verdict`, or any shell command.
  APPROVED: call tool {{.ToolPrefix}}liza_submit_verdict with params {"task_id": "{{.TaskID}}", "verdict": "APPROVED", "agent_id": "{{.AgentID}}"}
  REJECTED: call tool {{.ToolPrefix}}liza_submit_verdict with params {"task_id": "{{.TaskID}}", "verdict": "REJECTED", "agent_id": "{{.AgentID}}", "reason": "<detailed rejection reason>"}
- {{.ToolPrefix}}liza_await_resubmission — Block until doer resubmits after rejection (call after submit_verdict REJECTED)
  {"task_id": "{{.TaskID}}", "agent_id": "{{.AgentID}}"}
{{- end}}
{{- end -}}
