{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-init.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/git-guard.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["liza"],
  "additionalDirectories": ["~/.liza"],
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(~/.claude/**)",
      "Read(~/.liza/**)",
      "Read(~/.local/share/rtk/tee/**)",

      "mcp__liza__liza_get",
      "mcp__liza__liza_status",
      "mcp__liza__liza_validate",
      "mcp__liza__liza_version",
      "mcp__liza__liza_add_tasks",
      "mcp__liza__liza_claim_task",
      "mcp__liza__liza_submit_for_review",
      "mcp__liza__liza_await_verdict",
      "mcp__liza__liza_handoff",
      "mcp__liza__liza_submit_verdict",
      "mcp__liza__liza_mark_blocked",
      "mcp__liza__liza_release_claim",
      "mcp__liza__liza_supersede_task",
      "mcp__liza__liza_wt_create",
      "mcp__liza__liza_wt_delete",
      "mcp__liza__liza_wt_merge",
      "mcp__liza__liza_analyze",
      "mcp__liza__liza_update_sprint_metrics",
      "mcp__liza__liza_clear_stale_review_claims",
      "mcp__liza__liza_sprint_checkpoint",
      "mcp__liza__liza_write_checkpoint",
      "mcp__liza__liza_set_task_output",
      "mcp__liza__liza_assess_blocked",
      "mcp__liza__liza_assess_hypothesis_exhausted",
      "mcp__liza__liza_delete_agent",

      "Skill(adr-backfill)",
      "Skill(black-box-red-testing)",
      "Skill(clean-code)",
      "Skill(code-quality-assessment)",
      "Skill(code-review)",
      "Skill(code-spec-backfill)",
      "Skill(debugging)",
      "Skill(detailed-spec-writing)",
      "Skill(feynman)",
      "Skill(generic-subagent)",
      "Skill(have-you-considered)",
      "Skill(lesson-capture)",
      "Skill(liza-logs)",
      "Skill(software-architecture-review)",
      "Skill(spec-backfill)",
      "Skill(spec-review)",
      "Skill(systemic-thinking)",
      "Skill(testing)",
      "Skill(user-story-writing)",
      "Skill(white-box-red-testing)",

      "WebFetch",
      "WebSearch",
      "LSP",

      "Bash(liza:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(diff:*)",
      "Bash(realpath:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(cd:*)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(file:*)",
      "Bash(tree:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pre-commit:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(shellcheck:*)",
      "Bash(bash:*)",
      "Bash(ls:*)",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(sed:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(wc:*)",
      "Bash(date:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(go test:*)",
      "Bash(go mod:*)",
      "Bash(go build:*)",
      "Bash(make build)",
      "Bash(make test)",
      "Bash(make lint)",
      "Bash(rtk proxy:*)"
    ]
  }
}
