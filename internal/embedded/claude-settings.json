{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-init.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/git-guard.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/rtk-guard.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree-path-guard.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree-path-guard.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree-path-guard.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree-path-guard.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true,
  "additionalDirectories": ["~/.liza", "/tmp"],
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(~/.claude/**)",
      "Read(~/.liza/**)",
      "Write(/tmp/**)",

      "Skill(adr-backfill)",
      "Skill(architecture-planning)",
      "Skill(black-box-red-testing)",
      "Skill(checkpoint-summary)",
      "Skill(clean-code)",
      "Skill(code-quality-assessment)",
      "Skill(code-review)",
      "Skill(code-spec-backfill)",
      "Skill(context-engineering)",
      "Skill(debugging)",
      "Skill(detailed-spec-writing)",
      "Skill(epic-writing)",
      "Skill(feynman)",
      "Skill(generic-subagent)",
      "Skill(have-you-considered)",
      "Skill(lesson-capture)",
      "Skill(liza-logs)",
      "Skill(software-architecture-review)",
      "Skill(spec-backfill)",
      "Skill(spec-review)",
      "Skill(systemic-thinking)",
      "Skill(testing)",
      "Skill(user-story-writing)",
      "Skill(white-box-red-testing)",

      "WebFetch",
      "WebSearch",
      "LSP",
      "mcp__Ref__ref_read_url",
      "mcp__Ref__ref_search_documentation",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id",
      "mcp__deepwiki__ask_question",
      "mcp__deepwiki__read_wiki_contents",
      "mcp__deepwiki__read_wiki_structure",
      "mcp__fetch__fetch",
      "mcp__filesystem__directory_tree",
      "mcp__filesystem__get_file_info",
      "mcp__filesystem__read_file",
      "mcp__filesystem__read_multiple_files",
      "mcp__filesystem__read_text_file",
      "mcp__filesystem__search_files",
      "mcp__jetbrains__find_files_by_glob",
      "mcp__jetbrains__get_file_problems",
      "mcp__jetbrains__get_file_text_by_path",
      "mcp__jetbrains__get_project_dependencies",
      "mcp__jetbrains__get_project_modules",
      "mcp__jetbrains__get_symbol_info",
      "mcp__jetbrains__list_directory_tree",
      "mcp__jetbrains__read_file",
      "mcp__jetbrains__rename_refactoring",
