{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-init.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/git-guard.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/rtk-guard.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree-path-guard.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree-path-guard.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree-path-guard.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree-path-guard.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true,
  "additionalDirectories": ["~/.liza", "/tmp"],
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(~/.claude/**)",
      "Read(~/.liza/**)",
      "Write(/tmp/**)",

      "Skill(adr-backfill)",
      "Skill(architecture-planning)",
      "Skill(black-box-red-testing)",
      "Skill(clean-code)",
      "Skill(code-quality-assessment)",
      "Skill(code-review)",
      "Skill(code-spec-backfill)",
      "Skill(debugging)",
      "Skill(detailed-spec-writing)",
      "Skill(feynman)",
      "Skill(generic-subagent)",
      "Skill(have-you-considered)",
      "Skill(lesson-capture)",
      "Skill(liza-logs)",
      "Skill(software-architecture-review)",
      "Skill(spec-backfill)",
      "Skill(spec-review)",
      "Skill(systemic-thinking)",
      "Skill(testing)",
      "Skill(user-story-writing)",
      "Skill(white-box-red-testing)",

      "WebFetch",
      "WebSearch",
      "LSP",

      "Bash(liza:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(diff:*)",
      "Bash(realpath:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(cd:*)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(file:*)",
      "Bash(tree:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(mypy:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(pre-commit:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(uv:*)",
      "Bash(shellcheck:*)",
      "Bash(bash:*)",
      "Bash(ls:*)",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(sed:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(wc:*)",
      "Bash(date:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(go fmt:*)",
      "Bash(go test:*)",
      "Bash(go mod:*)",
      "Bash(go vet:*)",
      "Bash(go build:*)",
      "Bash(go -C:*)",
      "Bash(make build)",
      "Bash(make test)",
      "Bash(make lint)",
      "Bash(diff-cover:*)",

      "Bash(cargo:*)",
      "Bash(rustfmt:*)",
      "Bash(clippy-driver:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(tsc:*)",
      "Bash(vitest:*)"
    ]
  }
}
