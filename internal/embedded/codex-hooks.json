{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/enforce-init.sh\"",
            "statusMessage": "Checking Liza session initialization",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/git-guard.sh\"",
            "statusMessage": "Checking git command",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "^apply_patch$|^mcp__filesystem__|^mcp__morph-mcp__edit_file$",
        "hooks": [
          {
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/worktree-path-guard.sh\"",
            "statusMessage": "Checking worktree paths",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  }
}
